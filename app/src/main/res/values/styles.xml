<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/df_splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/dlaflow_splash_loader_static</item>
        <item name="postSplashScreenTheme">@style/AppTheme.Main</item>
    </style>

    <style name="AppTheme.Main" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">@font/inter_variable</item>
        <item name="android:windowBackground">@color/df_app_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/df_app_bg</item>
        <item name="android:statusBarColor">@color/df_app_bg</item>
        <item name="android:colorAccent">@color/df_primary</item>
    </style>
    <style name="CallerIdOverlayTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">@font/inter_variable</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:colorAccent">@color/df_primary</item>
    </style>
</resources>
